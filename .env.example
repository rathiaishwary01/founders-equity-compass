# CapStack — Environment Variables
# Copy this file to .env and fill in your values.
#
# The simulator works fully client-side without Supabase.
# You only need these if you want scenario save/load and shareable links.

# Your Supabase project URL (found in Project Settings → API)
VITE_SUPABASE_URL=your_supabase_project_url

# Your Supabase anon/public key (found in Project Settings → API)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Server-side equivalents (used during SSR via TanStack Start)
# These should match the VITE_ values above
SUPABASE_URL=your_supabase_project_url
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
